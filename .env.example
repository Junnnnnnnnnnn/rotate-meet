# =====================================================
# rotate-meet 환경 변수 템플릿
# =====================================================
# 이 파일을 복사해서 .env.local 또는 .env.production으로 만들고
# 실제 값을 채워 넣으세요.
#
# cp .env.example .env.local
# =====================================================

# -----------------------------------------------------
# Supabase
# -----------------------------------------------------
# Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# -----------------------------------------------------
# Cloudflare R2
# -----------------------------------------------------
# R2 대시보드 → Settings → S3 API endpoint URL의 서브도메인
CLOUDFLARE_ACCOUNT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# R2 API Token (Manage R2 API Tokens → Create API token)
CLOUDFLARE_R2_ACCESS_KEY_ID=
CLOUDFLARE_R2_SECRET_ACCESS_KEY=

# 버킷 이름
CLOUDFLARE_R2_PUBLIC_BUCKET=rotate-meet-public
CLOUDFLARE_R2_PRIVATE_BUCKET=rotate-meet-private

# 공개 버킷 R2.dev URL — Settings → Public Development URL → Enable 후 표시됨
R2_PUBLIC_BASE_URL=https://pub-xxxxxxxxxxxxxxxx.r2.dev

# -----------------------------------------------------
# Telegram
# -----------------------------------------------------
# BotFather(@BotFather)에서 /newbot 후 받은 토큰
TELEGRAM_BOT_TOKEN=1234567890:AAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 운영팀 그룹 채팅 ID (음수 — 예: -1001234567890)
TELEGRAM_CHAT_ID=-1001234567890

# Webhook 검증용 시크릿 (임의 문자열 32자 이상 권장, openssl rand -hex 32)
TELEGRAM_WEBHOOK_SECRET=replace_with_random_string_at_least_32_chars

# -----------------------------------------------------
# 사진 링크 (운영 알림에 박히는 신분증/직업인증 보기 링크)
# -----------------------------------------------------
# 배포된 앱의 공개 base URL (끝에 슬래시 없이)
# 텔레그램 메시지의 "🪪 신분증 보기" 링크가 이 도메인의 /api/photo/... 로 향함
APP_BASE_URL=https://rotate-meet.vercel.app

# 사진 링크 서명용 시크릿 (HMAC-SHA256). 32자 이상, openssl rand -hex 32
# TELEGRAM_WEBHOOK_SECRET와 다른 값을 사용 (키 재사용 시 사고 영향 범위 확대)
PHOTO_LINK_SECRET=replace_with_random_string_at_least_32_chars
